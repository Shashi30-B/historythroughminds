{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information, including budget and contact details.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name of the user." },
        "email": { "type": "string", "format": "email", "description": "Email address of the user." },
        "photo": { "type": "string", "description": "URL to the user's profile photo." },
        "phone": { "type": "string", "description": "User's phone number." },
        "totalBudget": { "type": "number", "description": "User's total travel budget in INR." },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp of account creation." }
      },
      "required": ["name", "email", "totalBudget", "created_at"]
    },
    "Trip": {
      "title": "Saved Trip",
      "description": "Stores a generated travel itinerary for a user.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string", "description": "UID of the user who saved the trip." },
        "start_location": { "type": "string", "description": "The starting point of the journey." },
        "location": { "type": "string", "description": "The destination of the trip." },
        "duration": { "type": "number", "description": "Duration of the trip in days." },
        "style": { "type": "string", "description": "Travel style (e.g., budget, luxury)." },
        "budget": { "type": "string", "description": "Formatted budget string." },
        "itinerary": { "type": "string", "description": "The full AI-generated itinerary text." },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp when the trip was saved." }
      },
      "required": ["user_id", "location", "duration", "style", "itinerary", "created_at"]
    },
    "Booking": {
      "title": "Booking History",
      "description": "Stores a user's booking history.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string", "description": "UID of the user." },
        "type": { "type": "string", "description": "Type of booking (hotel, flight, etc.)." },
        "details": { "type": "string", "description": "Details of the booking." },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp of the booking." }
      },
      "required": ["user_id", "type", "created_at"]
    },
    "Wishlist": {
      "title": "Wishlist Item",
      "description": "Stores a destination saved to a user's wishlist.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string", "description": "UID of the user." },
        "dest_id": { "type": "string", "description": "ID of the destination." },
        "title": { "type": "string", "description": "Title of the destination." },
        "img": { "type": "string", "description": "URL to the destination image." },
        "desc": { "type": "string", "description": "Description of the destination." },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp when added to wishlist." }
      },
      "required": ["user_id", "dest_id", "title", "created_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection."
    },
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Saved itineraries collection."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "User booking history collection."
    },
    "/wishlist/{wishlistId}": {
      "schema": "Wishlist",
      "description": "User wishlist collection."
    }
  }
}
